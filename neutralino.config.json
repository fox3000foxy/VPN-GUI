{
  "applicationId": "com.fox3000foxy.vpn-gui",
  "defaultMode": "window",
  "url": "/index.html",
  "documentRoot": "/dist/",
  "enableServer": true,
  "enableNativeAPI": true,
  "port": 0,
  "server": {
    "port": 5173,
    "strictPort": true,
    "hmr": {
      "port": 5173
    }
  },
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "window": {
    "title": "VPN GUI",
    "width": 800,
    "height": 600,
    "resizable": true
  },
  "modes": {
    "window": {
      "title": "FoxyProxies by Fox3000foxy",
      "width": 1200,
      "height": 800,
      "minWidth": 400,
      "minHeight": 200,
      "icon": "dist/icons/appIcon.png",
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "enableInspector": true,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": false
    },
    "browser": {
      "globalVariables": {
        "TEST": "Test value browser"
      },
      "nativeBlockList": [
        "filesystem.*"
      ]
    },
    "cloud": {
      "url": "/dist/#cloud",
      "nativeAllowList": [
        "app.*"
      ]
    },
    "chrome": {
      "width": 800,
      "height": 500,
      "args": "--user-agent=\"Neutralinojs chrome mode\"",
      "nativeBlockList": [
        "filesystem.*",
        "os.*"
      ]
    }
  },
  "platform": "windows",
  "cli": {
    "binaryName": "foxyproxies2",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/dist/js/neutralino.js",
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0"
  },
  "clientLib": "neutralino.js",
  "dist": "dist",
  "build": {
    "outputDir": "build",
    "files": [
      "**/*"
    ],
    "ignore": [
      "node_modules",
      "src",
      "public",
      "tor-expert-bundle",
      ".git",
      ".vscode",
      "neutralino.config.json"
    ]
  }
}